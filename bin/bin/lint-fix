#!/bin/bash
set -e

echo "=== Running golangci-lint ==="
golangci-lint run 2>&1 | tee .lint.txt

echo ""
read -p "Fix lint issues? [Y/n] " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Nn]$ ]]; then
  echo "=== Fixing lint issues with opencode ==="
  opencode run "Fix all golangci-lint issues reported in .lint.txt. Ensure no functional changes - only fix lint/style issues. Do not alter behavior."
else
  echo "Skipping fix."
  exit 0
fi

echo ""
echo "=== Re-running golangci-lint to verify ==="
golangci-lint run 2>&1 | tee .lint.txt
