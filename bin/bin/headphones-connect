#!/bin/bash

# Connect to a single Bluetooth headphone and set it as default audio output.
# Usage: headphones-connect "CMF Buds Pro 2"
# Exits 0 on success, 1 on failure.
# Set BT_QUIET=1 to suppress notifications (used by bt-audio recent walk).

NAME="$1"
NOTIFY="$HOME/bin/notify-send.sh"
ICON=~/.config/sway/icons/headphones.svg
RECENT_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/bt-audio-recent"

notify() {
	[[ -n "$BT_QUIET" ]] && return
	$NOTIFY "$1" \
		-t 2000 \
		-f \
		-i "$ICON"
}

# Prepend $NAME to the recency file, de-duplicated, most-recent first.
# ponytail: head -20 cap; bump if you ever pair more than 20 audio devices.
record_recent() {
	mkdir -p "$(dirname "$RECENT_FILE")"
	{
		echo "$NAME"
		[[ -f "$RECENT_FILE" ]] && grep -vxF "$NAME" "$RECENT_FILE"
	} | head -20 > "$RECENT_FILE.tmp" && mv "$RECENT_FILE.tmp" "$RECENT_FILE"
}

if [[ -z "$NAME" ]]; then
	notify "No headphone specified"
	exit 1
fi

paired_line=$(bluetoothctl devices Paired | grep -i "$NAME" || true)

if [[ -z "$paired_line" ]]; then
	notify "$NAME: not paired"
	exit 1
fi

mac=$(echo "$paired_line" | awk '{print $2}')
mac_underscored=${mac//:/_}

# Check if already connected
connected_line=$(bluetoothctl devices Connected | grep -i "$NAME" || true)

if [[ -z "$connected_line" ]]; then
	notify "$NAME: connecting..."
	if ! bluetoothctl connect "$mac" 2>&1 | tail -1; then
		notify "$NAME: failed to connect"
		exit 1
	fi

	# Wait for the Bluetooth sink to appear in PipeWire
	for i in $(seq 1 10); do
		sleep 1
		if pactl list sinks short 2>/dev/null | grep -q "$mac_underscored"; then
			break
		fi
		if [[ $i -eq 10 ]]; then
			notify "$NAME: connected but no audio sink"
			exit 1
		fi
	done
fi

# Find the sink name for these headphones
sink_name=$(pactl list sinks short | grep "$mac_underscored" | awk '{print $2}')

if [[ -z "$sink_name" ]]; then
	notify "$NAME: no audio sink found"
	exit 1
fi

# Set as default sink if not already
default_sink=$(pactl get-default-sink)

if [[ "$default_sink" != "$sink_name" ]]; then
	pactl set-default-sink "$sink_name"
fi

# Unmute if muted
if pactl get-sink-mute "$sink_name" | grep -q "yes"; then
	pactl set-sink-mute "$sink_name" 0
fi

record_recent
notify "$NAME: connected"
