#!/usr/bin/env bash

# ANSI color codes
GREEN='\033[32m'
YELLOW='\033[33m'
RESET='\033[0m'
BOLD='\033[1m'

get_session_name() {
	local path="$1"
	local depth=$(($(echo "$path" | awk -F/ '{print NF}') - 2))
	local base_name=$(basename "$path" | tr . _)
	if [[ $depth -gt 0 ]]; then
		local first_folder=$(basename "$(dirname "$path")")
		echo "${first_folder}>${base_name}"
	else
		echo "$base_name"
	fi
}

# Default list of folders
folders=(
	"$HOME/Projects"
	"$HOME/Personal"
	"$HOME/Scratch"
	"$HOME/Tools"
)

# Parse command-line arguments
found_folders=()
manual_folders=false
while [[ $# -gt 0 ]]; do
	case $1 in
	--folders)
		manual_folders=true
		shift
		while [[ $# -gt 0 && ! $1 =~ ^- ]]; do
			found_folders+=("$1")
			shift
		done
		;;
	*)
		shift
		;;
	esac
done

# If found_folders was passed via --folders, use it directly; otherwise search
if [[ ${#found_folders[@]} -eq 0 ]]; then
	# Generate find command to search within specified folders
	find_command="find -L "
	for folder in "${folders[@]}"; do
		find_command+="$folder "
	done
	find_command+="-mindepth 1 -maxdepth 3 -type f -name \".tmux-sessionizer\" | xargs -n1 dirname | sort -u | grep -v '/develop$'"
	mapfile -t found_folders < <(eval "$find_command")
fi

if [[ $# -eq 1 ]]; then
	selected=$1
else
	# Get list of active tmux sessions
	active_sessions=$(tmux list-sessions 2>/dev/null | cut -d: -f1 || echo "")

	# Get current session if inside tmux
	current_session=""
	if [[ -n $TMUX ]]; then
		current_session=$(tmux display-message -p '#S')
	fi

	# Format the default entries (only if not manually provided folders)
	fixed_entries=""
	if [[ "$manual_folders" = false ]]; then
		fixed_entries=$(
			echo "${BOLD}${YELLOW}~${RESET} home"
		)
	fi
	# Process and sort the project folders
	sorted_folders=$(
		printf '%s\n' "${found_folders[@]}" |
			sed 's#^\(/[^/]*\)\{2\}/##' |
			while read -r folder; do
				folder_name=${folder//\.git/}
				folder_name=$(get_session_name "$folder_name")

				if [[ "$folder_name" == "$current_session" ]]; then
					continue
				elif echo "$active_sessions" | grep -q "^${folder_name}$"; then
					# Add to bottom with green arrow
					echo "1:${GREEN}>${RESET} ${folder}"
				else
					# Add to top with dot
					echo "2:â€˘ ${folder}"
				fi
			done |
			sort -t: -k1,1 -k2 |
			cut -d: -f2-
	)

	# Combine fixed entries with sorted folders
	all_entries=$(echo -e "${sorted_folders}\n${fixed_entries}")

	# Create header with current session
	header="NO CURRENT SESSION"
	if [[ -n $current_session ]]; then
		header=$(echo -e "> ${current_session}")
	fi

	selected=$(
		echo -e "$all_entries" | fzf \
			--ansi \
			--header="$header" \
			--preview='lsd --icon always --group-dirs last --color always --oneline "$(echo {} | sed -E "s/^(\033\[[0-9;]*m)?[>â€˘~] /\/home\/arne\//;; s/\.git$/.git\/develop/")"' \
			--bind 'ctrl-x:execute-silent(echo {} >> /tmp/fzf_tmp)+accept' \
			--expect=ctrl-x
	)
	# --preview='erd --color force -I --suppress-size -L 1 --layout inverted "$(echo {} | sed -E "s/^(\033\[[0-9;]*m)?[>â€˘~] /\/home\/arne\//;; s/\.git$/.git\/develop/")"' \
	# --preview='tmux capture-pane -pe -t "$(echo {} | sed -E "s/^(\033\[[0-9;]*m)?[>â€˘~] //; s/\.git$//" | xargs basename)" | bat -p' \

	key=$(head -1 <<<"$selected")
	selection=$(tail -n +2 <<<"$selected")
	selected=$(echo "$selection" | sed -E 's/^(\033\[[0-9;]*m)?[>â€˘~] //')
fi

if [[ -z $selected ]]; then
	echo "No selection made, exiting."
	exit 0
fi

full_path=$HOME/$selected
if [[ $selected == *.git ]]; then
	full_path=$full_path/develop
	selected=${selected//\.git/}
elif [[ -d "$full_path/.bare" ]]; then
	full_path=$full_path/develop
fi

# Calculate depth and create session name format
selected_name=$(get_session_name "$selected")

if [ "$key" = "ctrl-x" ]; then
	tmux kill-session -t "$selected_name"
	tmux-sessionizer
	exit 0
fi

if [[ -z $selected ]]; then
	exit 0
fi

if ! tmux list-sessions 2>/dev/null | grep -q "^$selected_name:"; then
	tmux new-session -ds "$selected_name" -c "$full_path"

	tmux new-window -t "$selected_name:2" -c "$full_path"
	tmux kill-window -t "$selected_name:1"
	tmux new-window -t "$selected_name" -c "$full_path"
	tmux select-window -t "$selected_name:1"
fi

if [[ -z $TMUX ]]; then
	tmux attach-session -t "$selected_name"
else
	tmux switch-client -t "$selected_name"
fi
