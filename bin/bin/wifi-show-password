#!/usr/bin/env bash
# Show password and QR code for a saved WiFi network selected via fzf

set -euo pipefail

# List saved WiFi connections, pick one with fzf
SSID=$(nmcli -t -f NAME,TYPE connection show | awk -F: '$2 == "802-11-wireless" {print $1}' | fzf --prompt="Select WiFi network: ")

if [[ -z "$SSID" ]]; then
  echo "No network selected." >&2
  exit 1
fi

# Extract password from the connection profile
PASSWORD=$(nmcli -s -g 802-11-wireless-security.psk connection show "$SSID" 2>/dev/null)
SECURITY=$(nmcli -g 802-11-wireless-security.key-mgmt connection show "$SSID" 2>/dev/null)

# Map key-mgmt to QR security type
case "$SECURITY" in
  wpa-psk|sae) SEC="WPA" ;;
  wpa-eap*)    SEC="WPA" ;;
  wep)         SEC="WEP" ;;
  *)           SEC="nopass" ;;
esac

echo "SSID:     $SSID"
echo "Security: $SEC"
echo "Password: $PASSWORD"
echo

# Generate QR code if qrencode is available
if command -v qrencode &>/dev/null; then
  qrencode -t ANSIUTF8 "WIFI:T:${SEC};S:${SSID};P:${PASSWORD};;"
else
  echo "(install qrencode for QR code display)" >&2
fi
