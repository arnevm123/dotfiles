#!/usr/bin/env bash

be_session="base"
be_dir="Projects/base"
fe_session="cake"
fe_dir="Projects/cake"

be_cmd="${1:-run}"

ensure_session() {
	local dir="$1"
	local session="$2"

	if ! tmux has-session -t "$session" 2>/dev/null; then
		~/bin/tmux-sessionizer --no-attach "$dir"
		sleep 1
	fi

	if ! tmux list-windows -t "$session" 2>/dev/null | grep -q "^2:"; then
		tmux new-window -t "$session:2" -c "$(tmux display-message -p -t "$session" '#{session_path}')"
		sleep 0.5
	fi
}

run_in_window() {
	local session="$1"
	local cmd="$2"

	tmux send-keys -t "$session:2" C-c Enter
	tmux send-keys -t "$session:2" "make $cmd" Enter
	tmux select-window -t "$session:2"
}

# Phase 1: ensure both sessions and their windows exist
ensure_session "$be_dir" "$be_session"
ensure_session "$fe_dir" "$fe_session"

# Phase 2: run commands
run_in_window "$be_session" "$be_cmd"
run_in_window "$fe_session" "run"

if [[ -z "$TMUX" ]]; then
	exec tmux attach-session -t "$be_session"
else
	tmux switch-client -t "$be_session"
fi
