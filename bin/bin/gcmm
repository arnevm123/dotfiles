#!/bin/bash
VALID_TYPES=("feat" "fix" "chore" "docs" "style" "refactor" "perf" "test" "ci" "build" "revert" "boyscout")
type="${1%:}"
shift

set -- "$@" # reset args
message="$*"

ticket=$(git branch --show-current | grep -oP '^\d{1,6}(?=-)')

if [[ ! " ${VALID_TYPES[*]} " =~ " ${type} " ]]; then
    echo "❌ Invalid commit type: $type"
    echo "Allowed types: ${VALID_TYPES[*]}"
    exit 1
fi

if [[ -z "$message" ]]; then
    echo "❌ Message is empty."
    exit 1
fi

if [[ -n "$ticket" ]]; then
    echo "Constructing commit with footer: Refs #$ticket"
    git commit -m "${type}: ${message}" -m "Refs: #$ticket"
else
    echo "No ticket found in branch name. Committing without footer."
    git commit -m "${type}: ${message}"
fi
